generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  role      String    @default("user")
  avatar    String?
  createdAt DateTime  @default(now())
  assets    Asset[]
  sessions  Session[]
  clients   Client[]
  todos        Todo[]
  sopContents   SOPContent[]
  sopSteps     SOPStepContent[]
  invoices     Invoice[]
  expenses     Expense[]
}

model Client {
  id          String   @id @default(cuid())
  name        String
  status      String   @default("prospect")
  budget      Float?
  email       String   @default("")
  phone       String   @default("")
  address     String   @default("")
  siret       String   @default("")
  notes       String   @default("")
  tags        String   @default("")
  contact     String   @default("")
  driveUrl    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  description String?
  fileName    String
  fileType    String
  fileSize    Int
  mimeType    String
  category    String   @default("other")
  tags        String   @default("")
  url         String
  thumbnail   String?
  isPublic    Boolean  @default(true)
  uploadedBy  String
  user        User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  done        Boolean  @default(false)
  clientId    String?
  clientName  String   @default("")
  createdAt   DateTime @default(now())
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model SOPContent {
  id        String   @id @default(cuid())
  moduleId  String
  content   String   @default("")
  updatedAt DateTime @updatedAt
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([moduleId, createdBy])
}

model SOPStepContent {
  id        String   @id @default(cuid())
  stepId    String
  moduleId  String
  content   String   @default("")
  videoUrl  String   @default("")
  updatedAt DateTime @updatedAt
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([stepId, createdBy])
}

model Invoice {
  id            String   @id @default(cuid())
  type          String
  number        String
  status        String   @default("brouillon")
  clientId      String   @default("")
  clientName    String   @default("")
  clientEmail   String   @default("")
  clientAddress String   @default("")
  items         String   @default("[]")
  subtotal      Float    @default(0)
  taxRate       Float    @default(20)
  taxAmount     Float    @default(0)
  total         Float    @default(0)
  notes         String   @default("")
  validUntil    String   @default("")
  dueDate       String   @default("")
  issueDate     String   @default("")
  parentId      String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String
  user          User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model Expense {
  id        String   @id @default(cuid())
  label     String
  amount    Float
  category  String   @default("autre")
  date      String
  fileUrl   String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}
