generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String
  role      String    @default("user")
  avatar    String?
  createdAt DateTime  @default(now())
  assets    Asset[]
  sessions  Session[]
  clients   Client[]
  todos        Todo[]
  sopContents   SOPContent[]
  sopSteps     SOPStepContent[]
}

model Client {
  id          String   @id @default(cuid())
  name        String
  status      String   @default("prospect")
  budget      Float?
  notes       String   @default("")
  tags        String   @default("")
  contact     String   @default("")
  driveUrl    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  description String?
  fileName    String
  fileType    String
  fileSize    Int
  mimeType    String
  category    String   @default("other")
  tags        String   @default("")
  url         String
  thumbnail   String?
  isPublic    Boolean  @default(true)
  uploadedBy  String
  user        User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  done        Boolean  @default(false)
  clientId    String?
  clientName  String   @default("")
  createdAt   DateTime @default(now())
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model SOPContent {
  id        String   @id @default(cuid())
  moduleId  String
  content   String   @default("")
  updatedAt DateTime @updatedAt
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([moduleId, createdBy])
}

model SOPStepContent {
  id        String   @id @default(cuid())
  stepId    String
  moduleId  String
  content   String   @default("")
  videoUrl  String   @default("")
  updatedAt DateTime @updatedAt
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([stepId, createdBy])
}
